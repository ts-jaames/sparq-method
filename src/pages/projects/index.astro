---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageNav from '../../components/PageNav.astro';
---

<BaseLayout title="Projects">
    <div class="page-header">
        <h1>Projects</h1>
        <p class="page-header-desc">
            Applied operating models and delivery guidance for active engagements.
            Each project adapts the Evidence-Driven Delivery framework to its specific
            domain, risks, and team structure.
        </p>
        <div class="page-meta">
            <span class="page-reading-time">1 min read</span>
        </div>
    </div>

    <section>
        <h2>Active Engagements</h2>
        <div style="display:grid;grid-template-columns:1fr;gap:16px;max-width:640px;">
            <a href="/projects/copay-finder/" style="display:block;padding:24px;border:1px solid var(--border);border-radius:6px;text-decoration:none;transition:border-color 0.15s,background 0.15s;" onmouseover="this.style.borderColor='var(--accent)';this.style.background='var(--accent-bg)'" onmouseout="this.style.borderColor='var(--border)';this.style.background='transparent'">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                    <div style="font-size:12.5px;font-weight:600;color:var(--text);">Copay Finder</div>
                    <div style="font-size:9px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;padding:2px 8px;border-radius:10px;background:var(--green-bg);color:var(--green);border:1px solid rgba(34,197,94,0.2);">Active</div>
                </div>
                <div style="font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:var(--accent);margin-bottom:6px;">Aedificare Evidence-Driven Delivery Model</div>
                <div style="font-size:12.5px;color:var(--text-muted);line-height:1.6;">Operating model for AI-accelerated, confidence-driven product delivery on the Copay Finder platform.</div>
            </a>
        </div>
    </section>

    <PageNav prev={{ href: "/", title: "Overview" }} />
</BaseLayout>
