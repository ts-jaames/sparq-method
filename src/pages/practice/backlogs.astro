---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageNav from '../../components/PageNav.astro';
---

<BaseLayout title="Dual Backlogs">
    <div class="page-header">
        <h1>Dual Backlog Architecture</h1>
        <p class="page-header-desc">
            Evidence and Commitment are separate backlogs with distinct governance.
            Promotion from one to the other is never automatic — it requires explicit decision
            once defined confidence thresholds are exceeded.
        </p>
        <div class="page-meta">
            <span class="page-reading-time">2 min read</span>
        </div>
    </div>

    <section>
        <figure id="fig-4">
            <div class="diagram">
                <svg viewBox="0 0 860 390" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;">
                    <rect x="20" y="20" width="340" height="310" rx="6" fill="white" stroke="#e5e5e5" stroke-width="1"/>
                    <text x="40" y="50" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="10" font-weight="600" letter-spacing="0.05em" fill="#4a4a4a">EVIDENCE BACKLOG</text>
                    <text x="40" y="64" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Concept + Validation</text>
                    <circle cx="46" cy="90" r="1.5" fill="#a3a3a3"/><text x="56" y="93" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#737373">Time-boxed experiments</text>
                    <circle cx="46" cy="106" r="1.5" fill="#a3a3a3"/><text x="56" y="109" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#737373">Hypothesis tests</text>
                    <circle cx="46" cy="122" r="1.5" fill="#a3a3a3"/><text x="56" y="125" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#737373">Instrumented spikes</text>
                    <circle cx="46" cy="138" r="1.5" fill="#a3a3a3"/><text x="56" y="141" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#737373">Flexible scope</text>
                    <circle cx="46" cy="154" r="1.5" fill="#a3a3a3"/><text x="56" y="157" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#737373">No production commitments</text>
                    <line x1="40" y1="178" x2="340" y2="178" stroke="#e5e5e5" stroke-width="0.5"/>
                    <text x="40" y="198" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" letter-spacing="0.03em" fill="#a3a3a3">APPLIES WHEN</text>
                    <circle cx="46" cy="218" r="1.5" fill="#a3a3a3"/><text x="56" y="221" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Confidence below threshold</text>
                    <circle cx="46" cy="234" r="1.5" fill="#a3a3a3"/><text x="56" y="237" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Hypotheses unresolved</text>
                    <circle cx="46" cy="250" r="1.5" fill="#a3a3a3"/><text x="56" y="253" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Feasibility not proven</text>
                    <circle cx="46" cy="266" r="1.5" fill="#a3a3a3"/><text x="56" y="269" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Investment remains exploratory</text>

                    <rect x="500" y="20" width="340" height="310" rx="6" fill="white" stroke="#e5e5e5" stroke-width="1"/>
                    <text x="520" y="50" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="10" font-weight="600" letter-spacing="0.05em" fill="#4a4a4a">COMMITMENT BACKLOG</text>
                    <text x="520" y="64" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Commitment</text>
                    <circle cx="526" cy="90" r="1.5" fill="#a3a3a3"/><text x="536" y="93" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#737373">Production capabilities</text>
                    <circle cx="526" cy="106" r="1.5" fill="#a3a3a3"/><text x="536" y="109" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#737373">Scoped work</text>
                    <circle cx="526" cy="122" r="1.5" fill="#a3a3a3"/><text x="536" y="125" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#737373">Release-bound</text>
                    <circle cx="526" cy="138" r="1.5" fill="#a3a3a3"/><text x="536" y="141" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#737373">SLA-governed</text>
                    <circle cx="526" cy="154" r="1.5" fill="#a3a3a3"/><text x="536" y="157" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#737373">Validated scale</text>
                    <line x1="520" y1="178" x2="820" y2="178" stroke="#e5e5e5" stroke-width="0.5"/>
                    <text x="520" y="198" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" letter-spacing="0.03em" fill="#a3a3a3">APPLIES WHEN</text>
                    <circle cx="526" cy="218" r="1.5" fill="#a3a3a3"/><text x="536" y="221" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Confidence threshold exceeded</text>
                    <circle cx="526" cy="234" r="1.5" fill="#a3a3a3"/><text x="536" y="237" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Core risk reduced</text>
                    <circle cx="526" cy="250" r="1.5" fill="#a3a3a3"/><text x="536" y="253" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Architecture validated</text>
                    <circle cx="526" cy="266" r="1.5" fill="#a3a3a3"/><text x="536" y="269" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Promotion decision recorded</text>

                    <text x="190" y="355" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" fill="#525252">Evidence Backlog</text>
                    <line x1="270" y1="352" x2="350" y2="352" stroke="#d4d4d4" stroke-width="1"/><polygon points="348,349 356,352 348,355" fill="#d4d4d4"/>
                    <text x="430" y="355" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" fill="#E75437">Validated Hypothesis</text>
                    <line x1="510" y1="352" x2="590" y2="352" stroke="#d4d4d4" stroke-width="1"/><polygon points="588,349 596,352 588,355" fill="#d4d4d4"/>
                    <text x="670" y="355" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" fill="#525252">Commitment Backlog</text>
                </svg>
            </div>
            <figcaption>
                Promotion from Evidence to Commitment is never automatic. Transition requires
                explicit decision once defined confidence thresholds are exceeded.
                Both backlogs operate concurrently. Items may exist in either state simultaneously.
            </figcaption>
        </figure>
    </section>

    <PageNav
        prev={{ href: "/model/applied-flow/", title: "Applied Flow" }}
        next={{ href: "/practice/engagement/", title: "Engagement Shape" }}
    />
</BaseLayout>
