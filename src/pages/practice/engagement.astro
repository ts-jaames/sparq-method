        var r2 = document.createElementNS(NS, 'rect'); r2.setAttribute('x', '0'); r2.setAttribute('y', clipXBot); r2.setAttribute('width', svgW); r2.setAttribute('height', svgH - clipXBot); clip.appendChild(r2);
        throughDefs.appendChild(clip);
        var shotsG = document.createElementNS(NS, 'g'); shotsG.setAttribute('clip-path', 'url(#veraBehindClip)');
        var pathEls = throughG.querySelectorAll('path');
        for (var pp = 0; pp < pathEls.length; pp++) {
            var fullD = pathEls[pp].getAttribute('data-full-d') || pathEls[pp].getAttribute('d');
            for (var s = 0; s < 5; s++) {
                var shot = document.createElementNS(NS, 'rect'); shot.setAttribute('width', '6'); shot.setAttribute('height', '2'); shot.setAttribute('rx', '1');
                shot.setAttribute('fill', '#ec4899'); shot.setAttribute('opacity', '0'); shot.setAttribute('filter', 'url(#veraShotGlow)');
                var begin = (pp * 0.3 + s * (2.5 / 5)) + 's';
                var mot = document.createElementNS(NS, 'animateMotion'); mot.setAttribute('dur', '0.8s'); mot.setAttribute('repeatCount', 'indefinite');
                mot.setAttribute('begin', begin); mot.setAttribute('path', fullD); mot.setAttribute('rotate', 'auto'); shot.appendChild(mot);
                var oA = document.createElementNS(NS, 'animate'); oA.setAttribute('attributeName', 'opacity'); oA.setAttribute('values', '0;0.9;1;0.9;0');
                oA.setAttribute('keyTimes', '0;0.1;0.5;0.9;1'); oA.setAttribute('dur', '0.8s'); oA.setAttribute('repeatCount', 'indefinite'); oA.setAttribute('begin', begin); shot.appendChild(oA);
                shotsG.appendChild(shot);
            }
        }
        throughG.appendChild(shotsG);
    };

    // Traditional toggle
    var traditionalToggle = document.getElementById('traditionalToggle');
    var flowToggle = document.getElementById('flowToggle');
    var throughFlowToggleEl = document.getElementById('throughFlowToggle');
    var traditionalOn = false;
    var savedFlowState = true; var savedThroughState = false;

