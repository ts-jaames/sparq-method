<script is:inline>
var __dark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;

function initHero() {
    var el = document.getElementById('heroCanvas');
    if (!el || el.dataset.init) return;
    el.dataset.init = '1';

    var SIZE = el.offsetWidth;
    if (SIZE < 10) return;

    var dpr = window.devicePixelRatio || 1;
    el.width = SIZE * dpr;
    el.height = SIZE * dpr;

    var ctx = el.getContext('2d');
    if (!ctx) return;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    var COUNT = 1200;
    var COLOR = '#E75437';
    var STROKE_COLOR = '#F4845F';
    var cx = SIZE / 2;
    var cy = SIZE / 2;
    var radius = SIZE / 2 - 4;

    var particles = [];
    for (var i = 0; i < COUNT; i++) {
        var x, y;
        do { x = (Math.random() - 0.5) * 2; y = (Math.random() - 0.5) * 2; }
        while (x * x + y * y > 1);
        var speed = 0.0005 + Math.random() * 0.001;
        var angle = Math.random() * Math.PI * 2;
        particles.push({
            x: x, y: y,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
            r: 1.0 + Math.random() * 2.5,
            opacity: 0.15 + Math.random() * 0.55,
        });
    }

    var LINK_DIST = 0.25;
    var linkNodes = [];
    for (var li = 0; li < 180; li++) {
        linkNodes.push(particles[Math.floor(Math.random() * COUNT)]);
    }

    function tick() {
        if (!document.body.contains(el)) return;
        ctx.clearRect(0, 0, SIZE, SIZE);

        for (var j = 0; j < particles.length; j++) {
            var p = particles[j];
            p.x += (Math.random() - 0.5) * 0.002;
            p.y += (Math.random() - 0.5) * 0.002;
            p.x += p.vx;
            p.y += p.vy;
            var spd = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
            var MAX_SPD = 0.002;
            if (spd > MAX_SPD) { p.vx *= MAX_SPD / spd; p.vy *= MAX_SPD / spd; }
            p.x *= 0.9998;
            p.y *= 0.9998;
            var dist = Math.sqrt(p.x * p.x + p.y * p.y);
            if (dist > 0.95) {
                var nx = p.x / dist, ny = p.y / dist;
                var dot = p.vx * nx + p.vy * ny;
                p.vx -= 2 * dot * nx;
                p.vy -= 2 * dot * ny;
                p.x *= 0.94 / dist;
                p.y *= 0.94 / dist;
            }
        }

        ctx.strokeStyle = STROKE_COLOR;
        ctx.lineWidth = 0.8;
        for (var a = 0; a < linkNodes.length; a++) {
            var pi = linkNodes[a];
            for (var b = a + 1; b < linkNodes.length; b++) {
                var pj = linkNodes[b];
                var dx = pi.x - pj.x, dy = pi.y - pj.y;
                var d = Math.sqrt(dx * dx + dy * dy);
                if (d < LINK_DIST) {
                    ctx.globalAlpha = (1 - d / LINK_DIST) * 0.5;
                    ctx.beginPath();
                    ctx.moveTo(cx + pi.x * radius, cy + pi.y * radius);
                    ctx.lineTo(cx + pj.x * radius, cy + pj.y * radius);
                    ctx.stroke();
                }
            }
        }

        for (var j = 0; j < particles.length; j++) {
            var p = particles[j];
            ctx.beginPath();
            ctx.arc(cx + p.x * radius, cy + p.y * radius, p.r, 0, Math.PI * 2);
            ctx.fillStyle = COLOR;
            ctx.globalAlpha = p.opacity;
            ctx.fill();
        }
        ctx.globalAlpha = 1;
        requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
}

function initNucleus() {
    var el = document.getElementById('nucleusCanvas');
    if (!el || el.dataset.init) return;
    el.dataset.init = '1';

    var SIZE = 120;
    var COUNT = 560;
    var COLOR = '#E75437';

    var dpr = window.devicePixelRatio || 1;
    el.width = SIZE * dpr;
    el.height = SIZE * dpr;
    el.style.width = SIZE + 'px';
    el.style.height = SIZE + 'px';

    var ctx = el.getContext('2d');
    if (!ctx) return;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    var cx = SIZE / 2;
    var cy = SIZE / 2;
    var radius = SIZE / 2 - 2;

    var particles = [];
    for (var i = 0; i < COUNT; i++) {
        var x, y;
        do { x = (Math.random() - 0.5) * 2; y = (Math.random() - 0.5) * 2; }
        while (x * x + y * y > 1);
        var speed = 0.001 + Math.random() * 0.002;
        var angle = Math.random() * Math.PI * 2;
        particles.push({
            x: x, y: y,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
            r: 0.5 + Math.random() * 1.6,
            opacity: 0.2 + Math.random() * 0.6,
        });
    }

    var LINK_DIST = 0.35;
    var linkNodes = [];
    for (var li = 0; li < 100; li++) {
        linkNodes.push(particles[Math.floor(Math.random() * COUNT)]);
    }

    function tick() {
        if (!document.body.contains(el)) return;
        ctx.clearRect(0, 0, SIZE, SIZE);

        for (var j = 0; j < particles.length; j++) {
            var p = particles[j];
            p.x += (Math.random() - 0.5) * 0.003;
            p.y += (Math.random() - 0.5) * 0.003;
            p.x += p.vx;
            p.y += p.vy;
            var spd = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
            var MAX_SPD = 0.003;
            if (spd > MAX_SPD) { p.vx *= MAX_SPD / spd; p.vy *= MAX_SPD / spd; }
            p.x *= 0.9997;
            p.y *= 0.9997;
            var dist = Math.sqrt(p.x * p.x + p.y * p.y);
            if (dist > 0.95) {
                var nx = p.x / dist, ny = p.y / dist;
                var dot = p.vx * nx + p.vy * ny;
                p.vx -= 2 * dot * nx;
                p.vy -= 2 * dot * ny;
                p.x *= 0.94 / dist;
                p.y *= 0.94 / dist;
            }
        }

        ctx.strokeStyle = '#F4845F';
        ctx.lineWidth = 0.6;
        for (var a = 0; a < linkNodes.length; a++) {
            var pi = linkNodes[a];
            for (var b = a + 1; b < linkNodes.length; b++) {
                var pj = linkNodes[b];
                var dx = pi.x - pj.x, dy = pi.y - pj.y;
                var d = Math.sqrt(dx * dx + dy * dy);
                if (d < LINK_DIST) {
                    ctx.globalAlpha = (1 - d / LINK_DIST) * 0.7;
                    ctx.beginPath();
                    ctx.moveTo(cx + pi.x * radius, cy + pi.y * radius);
                    ctx.lineTo(cx + pj.x * radius, cy + pj.y * radius);
                    ctx.stroke();
                }
            }
        }

        for (var j = 0; j < particles.length; j++) {
            var p = particles[j];
            ctx.beginPath();
            ctx.arc(cx + p.x * radius, cy + p.y * radius, p.r, 0, Math.PI * 2);
            ctx.fillStyle = COLOR;
            ctx.globalAlpha = p.opacity;
            ctx.fill();
        }
        ctx.globalAlpha = 1;
        requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
}

function initMesh() {
    var el = document.getElementById('meshCanvas');
    if (!el || el.dataset.init) return;
    el.dataset.init = '1';

    var wrap = el.parentElement;
    var W = wrap.offsetWidth;
    var H = 100;
    var dpr = window.devicePixelRatio || 1;

    el.width = W * dpr;
    el.height = H * dpr;
    el.style.width = W + 'px';
    el.style.height = H + 'px';

    var ctx = el.getContext('2d');
    if (!ctx) return;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    var COLS = 80;
    var ROWS = 18;
    var COLOR = '#E75437';
    var time = 0;

    function draw() {
        if (!document.body.contains(el)) return;
        time += 0.007;
        ctx.clearRect(0, 0, W, H);

        var cellW = W / (COLS - 1);
        var cellH = H / (ROWS - 1);
        var pts = [];

        for (var r = 0; r < ROWS; r++) {
            var row = [];
            for (var c = 0; c < COLS; c++) {
                var x = c * cellW;
                var y = r * cellH;
                var nx = c / (COLS - 1);
                var ny = r / (ROWS - 1);
                var w1 = Math.sin(nx * 12 + time * 1.1 + ny * 3) * 10;
                var w2 = Math.sin(nx * 7 - time * 0.9 + ny * 5) * 8;
                var w3 = Math.cos(ny * 8 + nx * 4 + time * 0.7) * 6;
                var w4 = Math.sin(nx * 18 + ny * 6 - time * 1.3) * 4;
                var w5 = Math.cos(nx * 9 - ny * 3.5 + time * 0.5) * 5;
                y += w1 + w2 + w3 + w4 + w5;
                row.push({ x: x, y: y });
            }
            pts.push(row);
        }

        for (var r = 0; r < ROWS; r++) {
            var ny = r / (ROWS - 1);
            var yFade = Math.pow(Math.sin(ny * Math.PI), 0.7);
            ctx.beginPath();
            ctx.moveTo(pts[r][0].x, pts[r][0].y);
            for (var c = 1; c < COLS; c++) {
                ctx.lineTo(pts[r][c].x, pts[r][c].y);
            }
            ctx.strokeStyle = COLOR;
            ctx.globalAlpha = (0.06 + yFade * 0.22);
            ctx.lineWidth = 0.5;
            ctx.stroke();
        }

        for (var c = 0; c < COLS; c++) {
            var nx = c / (COLS - 1);
            var xFade = Math.pow(Math.sin(nx * Math.PI), 1.2);
            ctx.beginPath();
            ctx.moveTo(pts[0][c].x, pts[0][c].y);
            for (var r = 1; r < ROWS; r++) {
                ctx.lineTo(pts[r][c].x, pts[r][c].y);
            }
            ctx.strokeStyle = COLOR;
            ctx.globalAlpha = (0.04 + xFade * 0.15);
            ctx.lineWidth = 0.35;
            ctx.stroke();
        }

        ctx.globalAlpha = 1;
        requestAnimationFrame(draw);
    }

    requestAnimationFrame(draw);
}

function initMiniLoop() {
    var el = document.getElementById('miniLoopCanvas');
    if (!el || el.dataset.init) return;
    el.dataset.init = '1';

    var wrap = el.parentElement;
    var W = wrap.offsetWidth;
    var PAD = 40;
    var RX = (W / 2) - PAD;
    var RY = RX * 0.38;
    var H = RY * 0.75 + 40;

    var dpr = window.devicePixelRatio || 1;
    el.width = W * dpr;
    el.height = H * dpr;
    el.style.width = W + 'px';
    el.style.height = H + 'px';

    var ctx = el.getContext('2d');
    if (!ctx) return;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    var COLOR = '#E75437';
    var COUNT = 1000;
    var CX = W / 2, CY = H / 2;
    var TUBE = 10;
    var SPRING = 0.01;
    var DAMPING = 0.62;
    var BROWNIAN = 1.2;
    var TRAIL_STROKE = __dark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';

    function lemX(t) {
        var s = Math.sin(t), c = Math.cos(t);
        return CX + (RX * c) / (1 + s * s);
    }
    function lemY(t) {
        var s = Math.sin(t), c = Math.cos(t);
        return CY + (RY * s * c) / (1 + s * s);
    }
    function normalAtT(t) {
        var dt = 0.001;
        var dx = lemX(t + dt) - lemX(t - dt);
        var dy = lemY(t + dt) - lemY(t - dt);
        var len = Math.sqrt(dx * dx + dy * dy);
        return { x: -dy / len, y: dx / len };
    }

    var TRAIL_PTS = 300;
    var outerTrail = [], innerTrail = [];
    for (var i = 0; i <= TRAIL_PTS; i++) {
        var t = (i / TRAIL_PTS) * Math.PI * 2;
        var n = normalAtT(t);
        var bx = lemX(t), by = lemY(t);
        outerTrail.push({ x: bx + n.x * TUBE, y: by + n.y * TUBE });
        innerTrail.push({ x: bx - n.x * TUBE, y: by - n.y * TUBE });
    }

    var particles = [];
    for (var i = 0; i < COUNT; i++) {
        var t = (i / COUNT) * Math.PI * 2;
        var speed = 0.005 + Math.random() * 0.008;
        var nOff = (Math.random() - 0.5) * TUBE * 0.8;
        particles.push({ t: t, speed: speed, r: 0.7 + Math.random() * 1.4, opacity: 0.2 + Math.random() * 0.65, nOff: nOff, nVel: 0 });
    }

    function drawPath(pts) {
        ctx.beginPath();
        ctx.moveTo(pts[0].x, pts[0].y);
        for (var i = 1; i < pts.length; i++) ctx.lineTo(pts[i].x, pts[i].y);
        ctx.closePath();
    }

    function tick() {
        if (!document.body.contains(el)) return;
        ctx.clearRect(0, 0, W, H);

        ctx.save();
        drawPath(outerTrail);
        ctx.strokeStyle = TRAIL_STROKE;
        ctx.lineWidth = 0.4;
        ctx.stroke();
        ctx.restore();

        ctx.save();
        drawPath(innerTrail);
        ctx.strokeStyle = TRAIL_STROKE;
        ctx.lineWidth = 0.4;
        ctx.stroke();
        ctx.restore();

        for (var j = 0; j < particles.length; j++) {
            var p = particles[j];
            p.t += p.speed;
            if (p.t > Math.PI * 2) p.t -= Math.PI * 2;
            p.nVel += (Math.random() - 0.5) * BROWNIAN;
            p.nVel += -p.nOff * SPRING;
            p.nVel *= DAMPING;
            p.nOff += p.nVel;
            var limit = TUBE * 0.85;
            if (p.nOff > limit) { p.nOff = limit; p.nVel *= -0.3; }
            if (p.nOff < -limit) { p.nOff = -limit; p.nVel *= -0.3; }
            var n = normalAtT(p.t);
            var px = lemX(p.t) + n.x * p.nOff;
            var py = lemY(p.t) + n.y * p.nOff;
            ctx.beginPath();
            ctx.arc(px, py, p.r, 0, Math.PI * 2);
            ctx.fillStyle = COLOR;
            ctx.globalAlpha = p.opacity;
            ctx.fill();
        }
        ctx.globalAlpha = 1;
        requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
}

function initMaturity() {
    var el = document.getElementById('maturityCanvas');
    if (!el || el.dataset.init) return;
    el.dataset.init = '1';

    var wrap = el.parentElement;
    var W = wrap.offsetWidth;
    var H = 80;
    var dpr = window.devicePixelRatio || 1;

    el.width = W * dpr;
    el.height = H * dpr;
    el.style.width = W + 'px';
    el.style.height = H + 'px';

    var ctx = el.getContext('2d');
    if (!ctx) return;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    var COLOR = __dark ? '#4ADE80' : '#2D5F3E';
    var BASELINE = __dark ? '#333' : '#d4d4d4';
    var time = 0;
    var THIRD = W / 3;
    var PAD = 16;
    var NODE_R = 2.8;
    var zones = [];
    var CY = H / 2;
    var SPREAD_A = 14;
    var SPREAD_I = 18;
    var SPREAD_N = 22;

    (function() {
        var nodes = [];
        var count = 8;
        for (var i = 0; i < count; i++) {
            nodes.push({ x: PAD + Math.random() * (THIRD - PAD * 2), y: CY + (Math.random() - 0.5) * SPREAD_A * 2, vx: (Math.random() - 0.5) * 0.15, vy: (Math.random() - 0.5) * 0.08 });
        }
        zones.push({ nodes: nodes, edges: [[0, 2], [4, 6]], ox: 0, spread: SPREAD_A });
    })();

    (function() {
        var nodes = [];
        var count = 14;
        for (var i = 0; i < count; i++) {
            nodes.push({ x: PAD + Math.random() * (THIRD - PAD * 2), y: CY + (Math.random() - 0.5) * SPREAD_I * 2, vx: (Math.random() - 0.5) * 0.12, vy: (Math.random() - 0.5) * 0.08 });
        }
        var edges = [];
        for (var i = 0; i < count; i++) {
            var closest = -1; var dist = 9999;
            for (var j = 0; j < count; j++) {
                if (i === j) continue;
                var dx = nodes[i].x - nodes[j].x;
                var dy = nodes[i].y - nodes[j].y;
                var d = Math.sqrt(dx * dx + dy * dy);
                if (d < dist) { dist = d; closest = j; }
            }
            if (closest >= 0) edges.push([i, closest]);
            if (i % 3 === 0) {
                var sec = -1; var sd = 9999;
                for (var j = 0; j < count; j++) {
                    if (j === i || j === closest) continue;
                    var dx = nodes[i].x - nodes[j].x;
                    var dy = nodes[i].y - nodes[j].y;
                    var d = Math.sqrt(dx * dx + dy * dy);
                    if (d < sd) { sd = d; sec = j; }
                }
                if (sec >= 0) edges.push([i, sec]);
            }
        }
        zones.push({ nodes: nodes, edges: edges, ox: THIRD, spread: SPREAD_I });
    })();

    (function() {
        var nodes = [];
        var count = 24;
        for (var i = 0; i < count; i++) {
            nodes.push({ x: PAD + Math.random() * (THIRD - PAD * 2), y: CY + (Math.random() - 0.5) * SPREAD_N * 2, vx: (Math.random() - 0.5) * 0.2, vy: (Math.random() - 0.5) * 0.1 });
        }
        var edges = [];
        var CONN_DIST = (THIRD - PAD * 2) * 0.45;
        for (var i = 0; i < count; i++) {
            for (var j = i + 1; j < count; j++) {
                var dx = nodes[i].x - nodes[j].x;
                var dy = nodes[i].y - nodes[j].y;
                if (Math.sqrt(dx * dx + dy * dy) < CONN_DIST) edges.push([i, j]);
            }
        }
        zones.push({ nodes: nodes, edges: edges, ox: THIRD * 2, spread: SPREAD_N });
    })();

    function draw() {
        if (!document.body.contains(el)) return;
        time += 0.01;
        ctx.clearRect(0, 0, W, H);

        ctx.beginPath();
        ctx.moveTo(0, H / 2);
        ctx.lineTo(W, H / 2);
        ctx.strokeStyle = BASELINE;
        ctx.globalAlpha = 1;
        ctx.lineWidth = 0.5;
        ctx.stroke();

        for (var z = 0; z < zones.length; z++) {
            var zone = zones[z];
            var ns = zone.nodes;
            var es = zone.edges;
            var ox = zone.ox;

            for (var i = 0; i < ns.length; i++) {
                var n = ns[i];
                n.x += n.vx;
                n.y += n.vy;
                n.vx += (Math.random() - 0.5) * 0.02;
                n.vy += (Math.random() - 0.5) * 0.02;
                n.vx *= 0.98;
                n.vy *= 0.98;
                if (n.x < PAD) { n.x = PAD; n.vx = Math.abs(n.vx); }
                if (n.x > THIRD - PAD) { n.x = THIRD - PAD; n.vx = -Math.abs(n.vx); }
                var sp = zone.spread;
                if (n.y < CY - sp) { n.y = CY - sp; n.vy = Math.abs(n.vy); }
                if (n.y > CY + sp) { n.y = CY + sp; n.vy = -Math.abs(n.vy); }
            }

            for (var e = 0; e < es.length; e++) {
                var a = ns[es[e][0]];
                var b = ns[es[e][1]];
                var dx = a.x - b.x;
                var dy = a.y - b.y;
                var d = Math.sqrt(dx * dx + dy * dy);
                var maxD = z === 2 ? (THIRD - PAD * 2) * 0.45 : 999;
                var alpha = z === 0 ? 0.08 : z === 1 ? 0.12 : Math.max(0, 0.15 * (1 - d / maxD));
                alpha *= 0.7 + 0.3 * Math.sin(time * 2 + e * 0.5);
                ctx.beginPath();
                ctx.moveTo(ox + a.x, a.y);
                ctx.lineTo(ox + b.x, b.y);
                ctx.strokeStyle = COLOR;
                ctx.globalAlpha = alpha;
                ctx.lineWidth = z === 2 ? 0.8 : 0.6;
                ctx.stroke();
            }

            for (var i = 0; i < ns.length; i++) {
                var n = ns[i];
                var pulse = 0.5 + 0.5 * Math.sin(time * 1.5 + i * 1.1);
                var isAgent = z === 2 && (i === 3 || i === 11 || i === 19);
                var nodeColor = isAgent ? '#78FF59' : COLOR;
                ctx.beginPath();
                ctx.arc(ox + n.x, n.y, NODE_R, 0, Math.PI * 2);
                ctx.fillStyle = nodeColor;
                ctx.globalAlpha = 0.55;
                ctx.fill();
                if (z === 2) {
                    ctx.beginPath();
                    ctx.arc(ox + n.x, n.y, NODE_R + 3, 0, Math.PI * 2);
                    ctx.fillStyle = nodeColor;
                    ctx.globalAlpha = isAgent ? 0.12 * pulse : 0.06 * pulse;
                    ctx.fill();
                }
            }
        }

        ctx.globalAlpha = 1;
        requestAnimationFrame(draw);
    }

    requestAnimationFrame(draw);
}

function initAll() {
    initHero();
    initNucleus();
    initMesh();
    initMiniLoop();
    initMaturity();
}

initAll();
document.addEventListener('astro:page-load', function() {
    __dark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
    initAll();
});
</script>

</body>
