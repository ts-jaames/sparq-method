---
import { ViewTransitions } from 'astro:transitions';
import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Big Thing — AI-Enabled Engagement System</title>
    <ViewTransitions />
</head>
<body>
<div class="sos">

    <header class="sos-header">
        <a href="/" class="sos-back">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            Evidence-Driven Delivery
        </a>
        <h1>Big Thing</h1>
        <p>The engagement system defines what work exists.<br>AI governance defines where AI participates.<br>Work loops define how work happens.<br>Capability maturity determines how advanced AI usage is within each capability.</p>
    </header>

    <figure class="sos-diagram">
        <!-- Title + Engagement Lifecycle label -->
        <svg viewBox="0 0 880 56" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;display:block;">
            <style>.st{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif}</style>
            <text class="st" x="440" y="22" text-anchor="middle" font-size="26" font-weight="600" fill="#171717">Layers of the Big Thing</text>
            <text class="st" x="440" y="48" text-anchor="middle" font-size="10.5" fill="#737373">An AI-enabled system for discovering, building, and scaling software.</text>
        </svg>

        <div class="sos-section-label" style="margin-top:40px;margin-bottom:8px;">Engagement System</div>

        <!-- Nucleus: particle sphere replaces linear flow -->
        <div class="sos-nucleus-section">
            <div class="sos-nucleus-entry">
                <div class="sos-nucleus-sales">Sales / Pre-Sales</div>
                <svg class="sos-nucleus-arrow" width="40" height="14" viewBox="0 0 40 14"><path d="M0,7 L34,7 M30,3 L36,7 L30,11" stroke="#d4d4d4" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="sos-nucleus-wrap">
                <canvas id="nucleusCanvas" aria-hidden="true"></canvas>
            </div>
            <div class="sos-nucleus-labels">
                <span>Evidence, Scaling,</span>
                <span>Production Learning</span>
            </div>
        </div>

        <!-- AI Enablement & Governance: mesh gradient -->
        <div class="sos-mesh-section">
            <div class="sos-mesh-wrap">
                <canvas id="meshCanvas" aria-hidden="true"></canvas>
                <div class="sos-mesh-overlay">
                    <div class="sos-mesh-label">AI Enablement &amp; Governance</div>
                    <div class="sos-mesh-captions">Commercial · Product &amp; Strategy · Design · Engineering &amp; Data · Operations</div>
                </div>
            </div>
        </div>

        <!-- Middle: Work Loops animated figure-8 -->
        <div class="sos-miniloop-section">
            <div class="sos-miniloop-label">Work Loops</div>
            <div class="sos-miniloop-helper">The AI/SDLC lives inside the loop. It isn't the loop.</div>
            <div class="sos-miniloop-wrap">
                <canvas id="miniLoopCanvas" aria-hidden="true"></canvas>
                <div class="sos-miniloop-labels">
                    <div class="sos-miniloop-lbl sos-miniloop-lbl--left">
                        <span class="sos-miniloop-lbl-title">Evidence</span>
                        <span class="sos-miniloop-lbl-sub">Build to Validate</span>
                    </div>
                    <div class="sos-miniloop-lbl sos-miniloop-lbl--right">
                        <span class="sos-miniloop-lbl-title">Scale</span>
                        <span class="sos-miniloop-lbl-sub">Build to Operate</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom: Capability Maturity — State Transition -->
        <div class="sos-maturity-section">
            <div class="sos-section-label" style="margin-bottom:16px;">AI Capability Maturity</div>
            <div class="sos-maturity-labels">
                <div class="sos-maturity-lbl">
                    <span class="sos-maturity-title">Assisted</span>
                    <span class="sos-maturity-sub">Isolated tools</span>
                </div>
                <div class="sos-maturity-lbl">
                    <span class="sos-maturity-title">Integrated</span>
                    <span class="sos-maturity-sub">Connected workflows</span>
                </div>
                <div class="sos-maturity-lbl">
                    <span class="sos-maturity-title">AI-Native</span>
                    <span class="sos-maturity-sub">Autonomous agents</span>
                </div>
            </div>
            <div class="sos-maturity-band">
                <canvas id="maturityCanvas" aria-hidden="true"></canvas>
            </div>
        </div>
    </figure>

    <div class="sos-content">

        <p class="sos-intro">These layers are intentionally separated. Each represents a different type of decision and should be discussed independently.</p>

        <section class="sos-section">
            <h2>Engagement System</h2>
            <p>This layer defines the types of work that exist within an engagement and how they relate. It is not a sequence or process, but the structure within which work happens.</p>
            <div class="sos-tags">
                <span>Sales / Pre-Sales</span>
                <span>Evidence</span>
                <span>Scaling</span>
                <span>Production Learning</span>
            </div>
            <p>Work does not move linearly. Different types of work can occur in parallel, and capabilities shift between them based on confidence, not phase progression.</p>
            <p>This layer is stable, not AI-dependent, and acts as the container for everything else. It is also the level clients experience most directly.</p>
        </section>

        <section class="sos-section">
            <h2>AI Enablement &amp; Governance</h2>
            <p>This layer defines how AI is used across work. It does not define how work itself is structured. It answers where AI should participate and under what expectations.</p>
            <div class="sos-tags">
                <span>Strategy</span>
                <span>Design</span>
                <span>Engineering</span>
                <span>Delivery / Operations</span>
            </div>
            <p>It covers expectations, guardrails, where AI participates, and training and enablement. This is broader than the SDLC — the SDLC is one area inside this layer.</p>
        </section>

        <section class="sos-section">
            <h2>Work Flow Inside the Engagement System</h2>
            <p>Evidence and scale are two modes of work, not a required sequence.</p>

            <div class="sos-figure8-wrap">
                <canvas id="figure8Canvas" class="sos-figure8-canvas"></canvas>
                <div class="sos-figure8-labels">
                    <div class="sos-figure8-label sos-figure8-label--left">
                        <span class="sos-figure8-label-title">Evidence</span>
                        <span class="sos-figure8-label-sub">Build to Validate</span>
                    </div>
                    <div class="sos-figure8-label sos-figure8-label--right">
                        <span class="sos-figure8-label-title">Scale</span>
                        <span class="sos-figure8-label-sub">Build to Operate</span>
                    </div>
                </div>
            </div>

            <p>Evidence reduces uncertainty. Scale turns validated capabilities into production systems. Evidence work may continue while scale is underway as teams validate new assumptions, explore future capabilities, or reduce emerging risks.</p>
            <p>Work transitions when confidence crosses a threshold.</p>
            <div class="sos-flow-inline">
                <span>Evidence backlog</span>
                <span>Validated solution</span>
                <span>Delivery backlog</span>
                <span>Production feature</span>
            </div>
            <p>Work moves from evidence to scale when key uncertainties are resolved and confidence is high enough to commit to scalable implementation.</p>
        </section>

        <section class="sos-section">
            <h2>Work Loops</h2>
            <p>Inside each mode of work are repeating loops.</p>
            <div class="sos-loops-connected">
                <div class="sos-track">
                    <h3>Evidence Loop</h3>
                    <div class="sos-loop-steps">
                        <span>Explore</span>
                        <span>Prototype</span>
                        <span>Validate</span>
                    </div>
                </div>
                <div class="sos-loop-arrow-down">
                    <svg width="14" height="28" viewBox="0 0 14 28"><path d="M7 0 L7 22 M3 18 L7 26 L11 18" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="sos-track">
                    <h3>Delivery Loop</h3>
                    <div class="sos-loop-steps">
                        <span>Build</span>
                        <span>Test</span>
                        <span>Deploy</span>
                        <span>Observe</span>
                    </div>
                </div>
                <p class="sos-loop-note">Both loops may run simultaneously.</p>
            </div>
            <p>These loops describe how work tends to happen inside each mode. The SDLC conversation belongs here, not at the system level.</p>
        </section>

        <section class="sos-section">
            <h2>Capability Layer</h2>
            <p>People and skills. Each capability participates in different loops.</p>
            <div class="sos-tags">
                <span>Research</span>
                <span>Product strategy</span>
                <span>Design exploration</span>
                <span>Engineering</span>
                <span>Testing</span>
                <span>Architecture</span>
            </div>
            <p>Capabilities are the unit of movement between evidence and scale.</p>
        </section>

        <section class="sos-section">
            <h2>AI Maturity Layer</h2>
            <p>Maturity describes how a capability operates with AI, not a label assigned to it.</p>
            <div class="sos-tags">
                <span>Assisted</span>
                <span>Integrated</span>
                <span>AI-Native</span>
            </div>
            <p>Maturity exists per capability, not per project.</p>
            <table class="sos-table">
                <tbody>
                    <tr><td>Strategy</td><td>AI-Native</td></tr>
                    <tr><td>Design</td><td>Integrated</td></tr>
                    <tr><td>Engineering</td><td>Assisted</td></tr>
                </tbody>
            </table>
            <p>That's completely normal. Projects rarely have uniform maturity. Maturity changes how teams operate and what support they require.</p>
        </section>

        <section class="sos-section">
            <h2>Tooling Layer</h2>
            <p>Tooling supports maturity.</p>
            <div class="sos-two-tracks">
                <div class="sos-track">
                    <h3>Engineering</h3>
                    <p class="sos-track-sub">Integrated maturity</p>
                    <p class="sos-track-tools">Cursor, Copilot</p>
                </div>
                <div class="sos-track">
                    <h3>Strategy</h3>
                    <p class="sos-track-sub">AI-Native maturity</p>
                    <p class="sos-track-tools">Claude, research agents</p>
                </div>
            </div>
            <p>Tools support the system. They do not define it.</p>
        </section>

        <p class="sos-closing">The purpose of this frame is not to define everything in one place, but to make sure we're talking about the right thing at the right level.</p>

    </div>

</div>

<script is:inline>
function initNucleus() {
  var el = document.getElementById('nucleusCanvas');
  if (!el || el.dataset.init) return;
  el.dataset.init = '1';

  var SIZE = 120;
  var COUNT = 560;
  var COLOR = '#E75437';

  var dpr = window.devicePixelRatio || 1;
  el.width = SIZE * dpr;
  el.height = SIZE * dpr;
  el.style.width = SIZE + 'px';
  el.style.height = SIZE + 'px';

  var ctx = el.getContext('2d');
  if (!ctx) return;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

  var cx = SIZE / 2;
  var cy = SIZE / 2;
  var radius = SIZE / 2 - 2;

  var particles = [];
  for (var i = 0; i < COUNT; i++) {
    var x, y;
    do { x = (Math.random() - 0.5) * 2; y = (Math.random() - 0.5) * 2; }
    while (x * x + y * y > 1);
    var speed = 0.001 + Math.random() * 0.002;
    var angle = Math.random() * Math.PI * 2;
    particles.push({
      x: x, y: y,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      r: 0.5 + Math.random() * 1.6,
      opacity: 0.2 + Math.random() * 0.6,
    });
  }

  function tick() {
    if (!document.body.contains(el)) return;
    ctx.clearRect(0, 0, SIZE, SIZE);

    for (var j = 0; j < particles.length; j++) {
      var p = particles[j];

      p.x += (Math.random() - 0.5) * 0.003;
      p.y += (Math.random() - 0.5) * 0.003;

      p.x += p.vx;
      p.y += p.vy;

      var spd = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
      var MAX_SPD = 0.003;
      if (spd > MAX_SPD) { p.vx *= MAX_SPD / spd; p.vy *= MAX_SPD / spd; }

      p.x *= 0.9997;
      p.y *= 0.9997;

      var dist = Math.sqrt(p.x * p.x + p.y * p.y);
      if (dist > 0.95) {
        var nx = p.x / dist, ny = p.y / dist;
        var dot = p.vx * nx + p.vy * ny;
        p.vx -= 2 * dot * nx;
        p.vy -= 2 * dot * ny;
        p.x *= 0.94 / dist;
        p.y *= 0.94 / dist;
      }

      ctx.beginPath();
      ctx.arc(cx + p.x * radius, cy + p.y * radius, p.r, 0, Math.PI * 2);
      ctx.fillStyle = COLOR;
      ctx.globalAlpha = p.opacity;
      ctx.fill();
    }
    ctx.globalAlpha = 1;
    requestAnimationFrame(tick);
  }

  requestAnimationFrame(tick);
}

initNucleus();
document.addEventListener('astro:page-load', initNucleus);
</script>

<script is:inline>
function initMesh() {
  var el = document.getElementById('meshCanvas');
  if (!el || el.dataset.init) return;
  el.dataset.init = '1';

  var wrap = el.parentElement;
  var W = wrap.offsetWidth;
  var H = 100;
  var dpr = window.devicePixelRatio || 1;

  el.width = W * dpr;
  el.height = H * dpr;
  el.style.width = W + 'px';
  el.style.height = H + 'px';

  var ctx = el.getContext('2d');
  if (!ctx) return;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

  var COLS = 80;
  var ROWS = 18;
  var COLOR = '#E75437';
  var time = 0;

  function draw() {
    if (!document.body.contains(el)) return;
    time += 0.007;
    ctx.clearRect(0, 0, W, H);

    var cellW = W / (COLS - 1);
    var cellH = H / (ROWS - 1);
    var pts = [];

    for (var r = 0; r < ROWS; r++) {
      var row = [];
      for (var c = 0; c < COLS; c++) {
        var x = c * cellW;
        var y = r * cellH;
        var nx = c / (COLS - 1);
        var ny = r / (ROWS - 1);
        var w1 = Math.sin(nx * 12 + time * 1.1 + ny * 3) * 10;
        var w2 = Math.sin(nx * 7 - time * 0.9 + ny * 5) * 8;
        var w3 = Math.cos(ny * 8 + nx * 4 + time * 0.7) * 6;
        var w4 = Math.sin(nx * 18 + ny * 6 - time * 1.3) * 4;
        var w5 = Math.cos(nx * 9 - ny * 3.5 + time * 0.5) * 5;
        y += w1 + w2 + w3 + w4 + w5;
        row.push({ x: x, y: y });
      }
      pts.push(row);
    }

    for (var r = 0; r < ROWS; r++) {
      var ny = r / (ROWS - 1);
      var yFade = Math.pow(Math.sin(ny * Math.PI), 0.7);
      ctx.beginPath();
      ctx.moveTo(pts[r][0].x, pts[r][0].y);
      for (var c = 1; c < COLS; c++) {
        ctx.lineTo(pts[r][c].x, pts[r][c].y);
      }
      ctx.strokeStyle = COLOR;
      ctx.globalAlpha = (0.06 + yFade * 0.22);
      ctx.lineWidth = 0.5;
      ctx.stroke();
    }

    for (var c = 0; c < COLS; c++) {
      var nx = c / (COLS - 1);
      var xFade = Math.pow(Math.sin(nx * Math.PI), 1.2);
      ctx.beginPath();
      ctx.moveTo(pts[0][c].x, pts[0][c].y);
      for (var r = 1; r < ROWS; r++) {
        ctx.lineTo(pts[r][c].x, pts[r][c].y);
      }
      ctx.strokeStyle = COLOR;
      ctx.globalAlpha = (0.04 + xFade * 0.15);
      ctx.lineWidth = 0.35;
      ctx.stroke();
    }

    ctx.globalAlpha = 1;
    requestAnimationFrame(draw);
  }

  requestAnimationFrame(draw);
}

initMesh();
document.addEventListener('astro:page-load', initMesh);
</script>

<script is:inline>
function initMaturity() {
  var el = document.getElementById('maturityCanvas');
  if (!el || el.dataset.init) return;
  el.dataset.init = '1';

  var wrap = el.parentElement;
  var W = wrap.offsetWidth;
  var H = 80;
  var dpr = window.devicePixelRatio || 1;

  el.width = W * dpr;
  el.height = H * dpr;
  el.style.width = W + 'px';
  el.style.height = H + 'px';

  var ctx = el.getContext('2d');
  if (!ctx) return;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

  var COLOR = '#2D5F3E';
  var time = 0;
  var THIRD = W / 3;
  var PAD = 16;
  var NODE_R = 2.8;

  var zones = [];

  var CY = H / 2;
  var SPREAD_A = 14;
  var SPREAD_I = 18;
  var SPREAD_N = 22;

  // Assisted: scattered, few connections
  (function() {
    var nodes = [];
    var count = 8;
    for (var i = 0; i < count; i++) {
      nodes.push({
        x: PAD + Math.random() * (THIRD - PAD * 2),
        y: CY + (Math.random() - 0.5) * SPREAD_A * 2,
        vx: (Math.random() - 0.5) * 0.15,
        vy: (Math.random() - 0.5) * 0.08
      });
    }
    var edges = [[0, 2], [4, 6]];
    zones.push({ nodes: nodes, edges: edges, ox: 0, spread: SPREAD_A });
  })();

  // Integrated: connected workflow
  (function() {
    var nodes = [];
    var count = 14;
    for (var i = 0; i < count; i++) {
      nodes.push({
        x: PAD + Math.random() * (THIRD - PAD * 2),
        y: CY + (Math.random() - 0.5) * SPREAD_I * 2,
        vx: (Math.random() - 0.5) * 0.12,
        vy: (Math.random() - 0.5) * 0.08
      });
    }
    var edges = [];
    for (var i = 0; i < count; i++) {
      var closest = -1; var dist = 9999;
      for (var j = 0; j < count; j++) {
        if (i === j) continue;
        var dx = nodes[i].x - nodes[j].x;
        var dy = nodes[i].y - nodes[j].y;
        var d = Math.sqrt(dx * dx + dy * dy);
        if (d < dist) { dist = d; closest = j; }
      }
      if (closest >= 0) edges.push([i, closest]);
      // add a second connection for some nodes
      if (i % 3 === 0) {
        var sec = -1; var sd = 9999;
        for (var j = 0; j < count; j++) {
          if (j === i || j === closest) continue;
          var dx = nodes[i].x - nodes[j].x;
          var dy = nodes[i].y - nodes[j].y;
          var d = Math.sqrt(dx * dx + dy * dy);
          if (d < sd) { sd = d; sec = j; }
        }
        if (sec >= 0) edges.push([i, sec]);
      }
    }
    zones.push({ nodes: nodes, edges: edges, ox: THIRD, spread: SPREAD_I });
  })();

  // AI-Native: dense autonomous mesh
  (function() {
    var nodes = [];
    var count = 24;
    for (var i = 0; i < count; i++) {
      nodes.push({
        x: PAD + Math.random() * (THIRD - PAD * 2),
        y: CY + (Math.random() - 0.5) * SPREAD_N * 2,
        vx: (Math.random() - 0.5) * 0.2,
        vy: (Math.random() - 0.5) * 0.1
      });
    }
    var edges = [];
    var CONN_DIST = (THIRD - PAD * 2) * 0.45;
    for (var i = 0; i < count; i++) {
      for (var j = i + 1; j < count; j++) {
        var dx = nodes[i].x - nodes[j].x;
        var dy = nodes[i].y - nodes[j].y;
        if (Math.sqrt(dx * dx + dy * dy) < CONN_DIST) edges.push([i, j]);
      }
    }
    zones.push({ nodes: nodes, edges: edges, ox: THIRD * 2, spread: SPREAD_N });
  })();

  function draw() {
    if (!document.body.contains(el)) return;
    time += 0.01;
    ctx.clearRect(0, 0, W, H);

    // hairline spectrum baseline
    ctx.beginPath();
    ctx.moveTo(0, H / 2);
    ctx.lineTo(W, H / 2);
    ctx.strokeStyle = '#d4d4d4';
    ctx.globalAlpha = 1;
    ctx.lineWidth = 0.5;
    ctx.stroke();

    for (var z = 0; z < zones.length; z++) {
      var zone = zones[z];
      var ns = zone.nodes;
      var es = zone.edges;
      var ox = zone.ox;
      var zoneW = THIRD - PAD * 2;

      // drift nodes
      for (var i = 0; i < ns.length; i++) {
        var n = ns[i];
        n.x += n.vx;
        n.y += n.vy;
        // gentle brownian nudge
        n.vx += (Math.random() - 0.5) * 0.02;
        n.vy += (Math.random() - 0.5) * 0.02;
        // damping
        n.vx *= 0.98;
        n.vy *= 0.98;
        // bounds: horizontal full zone, vertical constrained to spread
        if (n.x < PAD) { n.x = PAD; n.vx = Math.abs(n.vx); }
        if (n.x > THIRD - PAD) { n.x = THIRD - PAD; n.vx = -Math.abs(n.vx); }
        var sp = zone.spread;
        if (n.y < CY - sp) { n.y = CY - sp; n.vy = Math.abs(n.vy); }
        if (n.y > CY + sp) { n.y = CY + sp; n.vy = -Math.abs(n.vy); }
      }

      // draw edges
      for (var e = 0; e < es.length; e++) {
        var a = ns[es[e][0]];
        var b = ns[es[e][1]];
        var dx = a.x - b.x;
        var dy = a.y - b.y;
        var d = Math.sqrt(dx * dx + dy * dy);
        var maxD = z === 2 ? (THIRD - PAD * 2) * 0.45 : 999;
        var alpha = z === 0 ? 0.08 : z === 1 ? 0.12 : Math.max(0, 0.15 * (1 - d / maxD));
        // pulse
        alpha *= 0.7 + 0.3 * Math.sin(time * 2 + e * 0.5);

        ctx.beginPath();
        ctx.moveTo(ox + a.x, a.y);
        ctx.lineTo(ox + b.x, b.y);
        ctx.strokeStyle = COLOR;
        ctx.globalAlpha = alpha;
        ctx.lineWidth = z === 2 ? 0.8 : 0.6;
        ctx.stroke();
      }

      // draw nodes
      for (var i = 0; i < ns.length; i++) {
        var n = ns[i];
        var pulse = 0.5 + 0.5 * Math.sin(time * 1.5 + i * 1.1);
        var nodeAlpha = 0.55;

        var isAgent = z === 2 && (i === 3 || i === 11 || i === 19);
        var nodeColor = isAgent ? '#78FF59' : COLOR;

        ctx.beginPath();
        ctx.arc(ox + n.x, n.y, NODE_R, 0, Math.PI * 2);
        ctx.fillStyle = nodeColor;
        ctx.globalAlpha = nodeAlpha;
        ctx.fill();

        // glow for AI-Native nodes
        if (z === 2) {
          ctx.beginPath();
          ctx.arc(ox + n.x, n.y, NODE_R + 3, 0, Math.PI * 2);
          ctx.fillStyle = nodeColor;
          ctx.globalAlpha = isAgent ? 0.12 * pulse : 0.06 * pulse;
          ctx.fill();
        }
      }
    }

    ctx.globalAlpha = 1;
    requestAnimationFrame(draw);
  }

  requestAnimationFrame(draw);
}

initMaturity();
document.addEventListener('astro:page-load', initMaturity);
</script>

<script is:inline>
function initMiniLoop() {
  var el = document.getElementById('miniLoopCanvas');
  if (!el || el.dataset.init) return;
  el.dataset.init = '1';

  var wrap = el.parentElement;
  var W = wrap.offsetWidth;
  var PAD = 40;
  var RX = (W / 2) - PAD;
  var RY = RX * 0.38;
  var H = RY * 0.75 + 40;

  var dpr = window.devicePixelRatio || 1;
  el.width = W * dpr;
  el.height = H * dpr;
  el.style.width = W + 'px';
  el.style.height = H + 'px';

  var ctx = el.getContext('2d');
  if (!ctx) return;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

  var COLOR = '#E75437';
  var COUNT = 1000;
  var CX = W / 2, CY = H / 2;
  var TUBE = 10;
  var SPRING = 0.01;
  var DAMPING = 0.62;
  var BROWNIAN = 1.2;

  function lemX(t) {
    var s = Math.sin(t), c = Math.cos(t);
    return CX + (RX * c) / (1 + s * s);
  }
  function lemY(t) {
    var s = Math.sin(t), c = Math.cos(t);
    return CY + (RY * s * c) / (1 + s * s);
  }
  function normalAtT(t) {
    var dt = 0.001;
    var dx = lemX(t + dt) - lemX(t - dt);
    var dy = lemY(t + dt) - lemY(t - dt);
    var len = Math.sqrt(dx * dx + dy * dy);
    return { x: -dy / len, y: dx / len };
  }

  var TRAIL_PTS = 300;
  var outerTrail = [], innerTrail = [];
  for (var i = 0; i <= TRAIL_PTS; i++) {
    var t = (i / TRAIL_PTS) * Math.PI * 2;
    var n = normalAtT(t);
    var bx = lemX(t), by = lemY(t);
    outerTrail.push({ x: bx + n.x * TUBE, y: by + n.y * TUBE });
    innerTrail.push({ x: bx - n.x * TUBE, y: by - n.y * TUBE });
  }

  var particles = [];
  for (var i = 0; i < COUNT; i++) {
    var t = (i / COUNT) * Math.PI * 2;
    var speed = 0.005 + Math.random() * 0.008;
    var nOff = (Math.random() - 0.5) * TUBE * 0.8;
    particles.push({
      t: t, speed: speed,
      r: 0.7 + Math.random() * 1.4,
      opacity: 0.2 + Math.random() * 0.65,
      nOff: nOff, nVel: 0,
    });
  }

  function drawPath(pts) {
    ctx.beginPath();
    ctx.moveTo(pts[0].x, pts[0].y);
    for (var i = 1; i < pts.length; i++) ctx.lineTo(pts[i].x, pts[i].y);
    ctx.closePath();
  }

  function tick() {
    if (!document.body.contains(el)) return;
    ctx.clearRect(0, 0, W, H);

    ctx.save();
    drawPath(outerTrail);
    ctx.strokeStyle = 'rgba(0,0,0,0.05)';
    ctx.lineWidth = 0.4;
    ctx.stroke();
    ctx.restore();

    ctx.save();
    drawPath(innerTrail);
    ctx.strokeStyle = 'rgba(0,0,0,0.05)';
    ctx.lineWidth = 0.4;
    ctx.stroke();
    ctx.restore();

    for (var j = 0; j < particles.length; j++) {
      var p = particles[j];
      p.t += p.speed;
      if (p.t > Math.PI * 2) p.t -= Math.PI * 2;

      p.nVel += (Math.random() - 0.5) * BROWNIAN;
      p.nVel += -p.nOff * SPRING;
      p.nVel *= DAMPING;
      p.nOff += p.nVel;

      var limit = TUBE * 0.85;
      if (p.nOff > limit) { p.nOff = limit; p.nVel *= -0.3; }
      if (p.nOff < -limit) { p.nOff = -limit; p.nVel *= -0.3; }

      var n = normalAtT(p.t);
      var px = lemX(p.t) + n.x * p.nOff;
      var py = lemY(p.t) + n.y * p.nOff;

      ctx.beginPath();
      ctx.arc(px, py, p.r, 0, Math.PI * 2);
      ctx.fillStyle = COLOR;
      ctx.globalAlpha = p.opacity;
      ctx.fill();
    }
    ctx.globalAlpha = 1;
    requestAnimationFrame(tick);
  }

  requestAnimationFrame(tick);
}

initMiniLoop();
document.addEventListener('astro:page-load', initMiniLoop);
</script>

