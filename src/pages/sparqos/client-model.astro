---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Client Model — Sparq OS">
<div class="cm">

    <header class="cm-hero">
        <p class="cm-badge">Sparq</p>
        <h1 class="cm-title">Deliver the right product faster.</h1>
        <p class="cm-subtitle">Evidence-driven validation meets AI-enabled execution.</p>
    </header>

    <section class="cm-section cm-reveal">
        <p class="cm-overline">The problem</p>
        <h2 class="cm-h2">Speed creates risk.</h2>
        <p class="cm-body">
            AI is making development faster. But the hardest problems
            in software delivery were never about writing code.
        </p>
        <div class="cm-points">
            <p>Building the wrong product</p>
            <p>Premature architecture decisions</p>
            <p>Scaling without confidence</p>
            <p>Late discovery of critical problems</p>
        </div>
        <p class="cm-accent-line">
            Faster development without better validation increases risk.
        </p>
    </section>

    <section class="cm-section cm-reveal">
        <p class="cm-overline">Our approach</p>
        <h2 class="cm-h2">Validate, then build.</h2>
        <div class="cm-duo">
            <div class="cm-duo-item">
                <span class="cm-duo-num">01</span>
                <h3>Evidence-Driven Validation</h3>
                <p>Test assumptions and reduce risk before committing to build.</p>
            </div>
            <div class="cm-duo-item">
                <span class="cm-duo-num">02</span>
                <h3>AI-Enabled Delivery</h3>
                <p>Accelerate design, engineering, and testing with modern AI.</p>
            </div>
        </div>
    </section>

    <section class="cm-section cm-reveal">
        <p class="cm-overline">How it works</p>
        <h2 class="cm-h2">Uncertainty to confidence.</h2>
        <div class="cm-process">
            <div class="cm-proc-step">
                <span class="cm-proc-num">01</span>
                <div>
                    <h3>Validate</h3>
                    <p>Test assumptions. Explore architecture. Validate direction.</p>
                </div>
            </div>
            <div class="cm-proc-step">
                <span class="cm-proc-num">02</span>
                <div>
                    <h3>Commit</h3>
                    <p>Reduce risk, then move forward with validated decisions.</p>
                </div>
            </div>
            <div class="cm-proc-step">
                <span class="cm-proc-num">03</span>
                <div>
                    <h3>Deliver</h3>
                    <p>AI-accelerated workflows for development, testing, and documentation.</p>
                </div>
            </div>
            <div class="cm-proc-step">
                <span class="cm-proc-num">04</span>
                <div>
                    <h3>Learn</h3>
                    <p>Production signals feed back to improve future decisions.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="cm-section cm-reveal">
        <p class="cm-overline">The impact</p>
        <div class="cm-outcomes">
            <span>Reduced delivery risk</span>
            <span>Less rework</span>
            <span>Faster timelines</span>
            <span>Better architecture</span>
            <span>Higher confidence</span>
        </div>
        <p class="cm-impact-line">
            Organizations investing millions in new platforms cannot rely on speed alone.
            They need confidence before commitment.
        </p>
    </section>

    <section class="cm-result cm-reveal">
        <h2>The right decisions, made earlier.</h2>
        <p>
            Teams move faster because uncertainty was resolved before commitment.
            The result is better products and stronger returns.
        </p>
    </section>

    <section class="cm-section cm-reveal">
        <p class="cm-overline">AI maturity</p>
        <h2 class="cm-h2">Meet teams where they are.</h2>
        <div class="cm-maturity">
            <div class="cm-mat">
                <div class="cm-mat-bar cm-mat-bar--1"></div>
                <h3>Assisted</h3>
                <p>AI supports individuals</p>
            </div>
            <div class="cm-mat">
                <div class="cm-mat-bar cm-mat-bar--2"></div>
                <h3>Integrated</h3>
                <p>AI in team workflows</p>
            </div>
            <div class="cm-mat">
                <div class="cm-mat-bar cm-mat-bar--3"></div>
                <h3>AI-Native</h3>
                <p>AI across the lifecycle</p>
            </div>
        </div>
        <p class="cm-mat-note">
            Modernize delivery at any stage of AI adoption — without disrupting existing teams.
        </p>
    </section>

    <footer class="cm-close cm-reveal">
        <p class="cm-close-lead">What we deliver</p>
        <h2 class="cm-close-statement">A modern delivery system for the AI era.</h2>
        <div class="cm-close-line"></div>
        <p class="cm-close-body">
            We help organizations reduce delivery risk and accelerate development
            by combining evidence-driven decision making with AI-enabled delivery.
        </p>
    </footer>

</div>

<script is:inline>
function initCmReveal() {
    var els = document.querySelectorAll('.cm-reveal');
    if (!els.length) return;
    var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
            if (e.isIntersecting) { e.target.classList.add('cm-in'); obs.unobserve(e.target); }
        });
    }, { threshold: 0.08, rootMargin: '0px 0px -20px 0px' });
    els.forEach(function(el) { obs.observe(el); });
}
initCmReveal();
document.addEventListener('astro:page-load', initCmReveal);
</script>
</BaseLayout>

<style>
    /* ═══ Client Model — Linear-inspired dark canvas ═══ */

    :global(.main-content:has(.cm)) {
        background: #09090b;
    }

    .cm {
        margin: -48px -48px -80px;
        padding: 56px 56px 80px;
        background: #09090b;
        background-image: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(231,84,55,0.04), transparent);
        min-height: 100vh;
        color: rgba(255,255,255,0.88);
    }

    /* ── Reveal ── */
    .cm-reveal {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .cm-reveal.cm-in {
        opacity: 1;
        transform: none;
    }

    /* ── Hero ── */
    .cm-hero {
        padding: 80px 0 96px;
    }
    .cm-badge {
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255,255,255,0.3);
        margin-bottom: 32px;
        display: block;
    }
    .cm-title {
        font-size: 48px;
        font-weight: 600;
        line-height: 1.1;
        letter-spacing: -0.035em;
        margin-bottom: 20px;
        max-width: 600px;
        background: linear-gradient(180deg, #ffffff 0%, rgba(255,255,255,0.4) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .cm-subtitle {
        font-size: 16px;
        line-height: 1.6;
        color: rgba(255,255,255,0.4);
        max-width: 460px;
    }

    /* ── Section rhythm ── */
    .cm-section {
        padding: 64px 0;
        border-top: 1px solid rgba(255,255,255,0.06);
    }
    .cm-overline {
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255,255,255,0.25);
        margin-bottom: 16px;
    }
    .cm-h2 {
        font-size: 24px;
        font-weight: 600;
        line-height: 1.3;
        letter-spacing: -0.02em;
        color: rgba(255,255,255,0.88);
        margin-bottom: 20px;
    }
    .cm-body {
        font-size: 15px;
        line-height: 1.7;
        color: rgba(255,255,255,0.45);
        max-width: 520px;
        margin-bottom: 32px;
    }

    /* ── Pain points ── */
    .cm-points {
        margin-bottom: 32px;
    }
    .cm-points p {
        font-size: 14px;
        font-weight: 500;
        color: rgba(255,255,255,0.4);
        padding: 12px 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        transition: color 0.25s ease;
    }
    .cm-points p:last-child { border-bottom: none; }
    .cm-points p:hover { color: rgba(255,255,255,0.8); }

    .cm-accent-line {
        font-size: 14px;
        line-height: 1.7;
        color: rgba(255,255,255,0.6);
        padding-left: 16px;
        border-left: 2px solid #E75437;
    }

    /* ── Duo / Approach ── */
    .cm-duo {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
    }
    .cm-duo-item {
        padding: 0 40px;
    }
    .cm-duo-item:first-child {
        padding-left: 0;
        border-right: 1px solid rgba(255,255,255,0.06);
    }
    .cm-duo-item:last-child {
        padding-right: 0;
    }
    .cm-duo-num {
        display: block;
        font-size: 11px;
        font-weight: 500;
        font-family: var(--mono);
        color: rgba(255,255,255,0.2);
        margin-bottom: 14px;
    }
    .cm-duo-item h3 {
        font-size: 16px;
        font-weight: 600;
        color: rgba(255,255,255,0.85);
        margin-bottom: 8px;
        letter-spacing: -0.01em;
    }
    .cm-duo-item p {
        font-size: 14px;
        line-height: 1.65;
        color: rgba(255,255,255,0.4);
    }

    /* ── Process ── */
    .cm-process {
        display: flex;
        flex-direction: column;
    }
    .cm-proc-step {
        display: flex;
        align-items: flex-start;
        gap: 20px;
        padding: 20px 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .cm-proc-step:last-child { border-bottom: none; }
    .cm-proc-num {
        font-size: 12px;
        font-weight: 500;
        font-family: var(--mono);
        color: rgba(255,255,255,0.18);
        width: 28px;
        flex-shrink: 0;
        padding-top: 2px;
    }
    .cm-proc-step h3 {
        font-size: 15px;
        font-weight: 600;
        color: rgba(255,255,255,0.85);
        margin-bottom: 4px;
    }
    .cm-proc-step p {
        font-size: 14px;
        line-height: 1.6;
        color: rgba(255,255,255,0.35);
    }

    /* ── Outcomes ── */
    .cm-outcomes {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 32px;
    }
    .cm-outcomes span {
        font-size: 13px;
        font-weight: 500;
        padding: 8px 20px;
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 100px;
        color: rgba(255,255,255,0.55);
        transition: border-color 0.25s ease, color 0.25s ease;
    }
    .cm-outcomes span:hover {
        border-color: rgba(255,255,255,0.15);
        color: rgba(255,255,255,0.85);
    }
    .cm-impact-line {
        font-size: 14px;
        line-height: 1.7;
        color: rgba(255,255,255,0.35);
        max-width: 480px;
    }

    /* ── Result ── */
    .cm-result {
        padding: 80px 0;
        border-top: 1px solid rgba(255,255,255,0.06);
        text-align: center;
    }
    .cm-result h2 {
        font-size: 30px;
        font-weight: 600;
        line-height: 1.25;
        letter-spacing: -0.025em;
        max-width: 480px;
        margin: 0 auto 16px;
        background: linear-gradient(180deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.45) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .cm-result p {
        font-size: 15px;
        line-height: 1.7;
        color: rgba(255,255,255,0.35);
        max-width: 420px;
        margin: 0 auto;
    }

    /* ── Maturity ── */
    .cm-maturity {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 24px;
        margin-bottom: 28px;
    }
    .cm-mat-bar {
        height: 2px;
        border-radius: 1px;
        margin-bottom: 16px;
    }
    .cm-mat-bar--1 { background: rgba(255,255,255,0.1); width: 33%; }
    .cm-mat-bar--2 { background: rgba(255,255,255,0.25); width: 66%; }
    .cm-mat-bar--3 { background: linear-gradient(90deg, rgba(255,255,255,0.4), #E75437); width: 100%; }
    .cm-mat h3 {
        font-size: 14px;
        font-weight: 600;
        color: rgba(255,255,255,0.8);
        margin-bottom: 4px;
    }
    .cm-mat p {
        font-size: 13px;
        color: rgba(255,255,255,0.3);
        line-height: 1.5;
    }
    .cm-mat-note {
        font-size: 14px;
        line-height: 1.65;
        color: rgba(255,255,255,0.35);
    }

    /* ── Close ── */
    .cm-close {
        padding: 80px 0 0;
        border-top: 1px solid rgba(255,255,255,0.06);
        text-align: center;
    }
    .cm-close-lead {
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255,255,255,0.2);
        margin-bottom: 20px;
    }
    .cm-close-statement {
        font-size: 36px;
        font-weight: 600;
        line-height: 1.15;
        letter-spacing: -0.03em;
        margin-bottom: 0;
        background: linear-gradient(180deg, #ffffff 0%, rgba(255,255,255,0.4) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .cm-close-line {
        width: 32px;
        height: 1px;
        background: rgba(255,255,255,0.12);
        margin: 28px auto;
    }
    .cm-close-body {
        font-size: 15px;
        line-height: 1.7;
        color: rgba(255,255,255,0.35);
        max-width: 480px;
        margin: 0 auto;
    }

    /* ── Responsive ── */
    @media (max-width: 800px) {
        .cm { padding: 40px 28px 60px; }
        .cm-hero { padding: 48px 0 64px; }
        .cm-title { font-size: 34px; }
        .cm-duo { grid-template-columns: 1fr; gap: 32px; }
        .cm-duo-item { padding: 0; }
        .cm-duo-item:first-child { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); padding-bottom: 32px; }
        .cm-maturity { grid-template-columns: 1fr; gap: 20px; }
        .cm-result h2 { font-size: 24px; }
        .cm-close-statement { font-size: 28px; }
    }
</style>
