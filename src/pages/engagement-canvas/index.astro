---
import EngagementCanvas from '../../components/canvas/EngagementCanvas';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Engagement System Canvas — Sparq OS</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { width: 100%; height: 100%; overflow: hidden; background: #0e0e0e; color-scheme: dark; }
        .react-flow__controls button { background: #1a1a1a; border-color: #2a2a2a; color: #888; fill: #888; }
        .react-flow__controls button:hover { background: #222; }
        .react-flow__edge-textbg { fill: #111; }
        @keyframes gateGlow {
            0%, 100% { box-shadow: 0 0 12px rgba(34,211,238,0.25), 0 0 24px rgba(34,211,238,0.12); }
            50% { box-shadow: 0 0 20px rgba(34,211,238,0.4), 0 0 40px rgba(34,211,238,0.2); }
        }
        .gate-glow { animation: gateGlow 2.5s ease-in-out infinite; }
    </style>
</head>
<body>
    <EngagementCanvas client:only="react" />
</body>
</html>
