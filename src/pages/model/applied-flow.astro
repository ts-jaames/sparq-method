---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageNav from '../../components/PageNav.astro';
---

<BaseLayout title="Applied Flow">
    <div class="page-header">
        <h1>Applied Flow</h1>
        <p class="page-header-desc">
            Work advances incrementally. Individual capabilities promote only when confidence
            thresholds are exceeded. Items that fail a gate may iterate or be killed outright.
        </p>
        <div class="page-meta">
            <span class="page-reading-time">3 min read</span>
        </div>
    </div>

    <section>
        <figure id="fig-3">
            <div class="fig-label">Fig. 3 — Applied Engagement Flow</div>
            <div class="diagram">
                <svg viewBox="0 0 900 420" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;">
                    <defs>
                        <pattern id="dotGrid3" patternUnits="userSpaceOnUse" width="10" height="10">
                            <circle cx="5" cy="5" r="1.2" fill="#c5c5c5"/>
                        </pattern>
                        <radialGradient id="cornerBR3" cx="620" cy="310" r="380" gradientUnits="userSpaceOnUse">
                            <stop offset="0%" stop-color="white" stop-opacity="0.55"/>
                            <stop offset="30%" stop-color="white" stop-opacity="0.4"/>
                            <stop offset="55%" stop-color="white" stop-opacity="0.18"/>
                            <stop offset="72%" stop-color="white" stop-opacity="0.04"/>
                            <stop offset="82%" stop-color="white" stop-opacity="0"/>
                        </radialGradient>
                        <radialGradient id="cornerTL3" cx="100" cy="60" r="340" gradientUnits="userSpaceOnUse">
                            <stop offset="0%" stop-color="white" stop-opacity="0.55"/>
                            <stop offset="30%" stop-color="white" stop-opacity="0.4"/>
                            <stop offset="55%" stop-color="white" stop-opacity="0.18"/>
                            <stop offset="72%" stop-color="white" stop-opacity="0.04"/>
                            <stop offset="82%" stop-color="white" stop-opacity="0"/>
                        </radialGradient>
                        <mask id="zoneMask3">
                            <rect x="100" y="60" width="530" height="250" fill="url(#cornerBR3)"/>
                            <rect x="100" y="60" width="530" height="250" fill="url(#cornerTL3)"/>
                        </mask>
                    </defs>
                    <rect x="100" y="60" width="530" height="250" fill="url(#dotGrid3)" mask="url(#zoneMask3)"/>
                    <circle cx="100" cy="310" r="4" fill="#4a4a4a"/>
                    <line x1="100" y1="310" x2="100" y2="60" stroke="#4a4a4a" stroke-width="1.5"/>
                    <polygon points="96,64 100,52 104,64" fill="#4a4a4a"/>
                    <line x1="94" y1="270" x2="106" y2="270" stroke="#d4d4d4" stroke-width="1"/>
                    <line x1="94" y1="185" x2="106" y2="185" stroke="#d4d4d4" stroke-width="1"/>
                    <line x1="94" y1="100" x2="106" y2="100" stroke="#d4d4d4" stroke-width="1"/>
                    <text x="94" y="274" text-anchor="end" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Low Confidence</text>
                    <text x="94" y="189" text-anchor="end" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Medium Confidence</text>
                    <text x="94" y="104" text-anchor="end" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">High Confidence</text>
                    <text x="100" y="32" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="10" font-weight="600" letter-spacing="0.05em" fill="#4a4a4a">EVIDENCE WORK</text>
                    <text x="100" y="44" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Confidence Earned</text>
                    <line x1="100" y1="310" x2="620" y2="310" stroke="#4a4a4a" stroke-width="1.5"/>
                    <polygon points="616,306 628,310 616,314" fill="#4a4a4a"/>
                    <line x1="220" y1="304" x2="220" y2="316" stroke="#d4d4d4" stroke-width="1"/>
                    <line x1="380" y1="304" x2="380" y2="316" stroke="#d4d4d4" stroke-width="1"/>
                    <line x1="540" y1="304" x2="540" y2="316" stroke="#d4d4d4" stroke-width="1"/>
                    <text x="220" y="332" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Concept</text>
                    <text x="380" y="332" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Validation</text>
                    <text x="540" y="332" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Commitment</text>
                    <text x="640" y="305" text-anchor="start" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="10" font-weight="600" letter-spacing="0.05em" fill="#4a4a4a">BUILD LIFECYCLE</text>
                    <text x="640" y="317" text-anchor="start" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Investment Intensity</text>
                    <line x1="300" y1="70" x2="300" y2="305" stroke="#d4d4d4" stroke-width="1" stroke-dasharray="4 3"/>
                    <line x1="294" y1="305" x2="306" y2="305" stroke="#4a4a4a" stroke-width="1.5"/>
                    <line x1="294" y1="70" x2="306" y2="70" stroke="#4a4a4a" stroke-width="1.5"/>
                    <text x="300" y="365" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" fill="#a3a3a3">Confidence Gate</text>
                    <line x1="460" y1="70" x2="460" y2="305" stroke="#d4d4d4" stroke-width="1" stroke-dasharray="4 3"/>
                    <line x1="454" y1="305" x2="466" y2="305" stroke="#4a4a4a" stroke-width="1.5"/>
                    <line x1="454" y1="70" x2="466" y2="70" stroke="#4a4a4a" stroke-width="1.5"/>
                    <text x="460" y="365" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" fill="#a3a3a3">Confidence Gate</text>
                    <!-- Item A -->
                    <path d="M140,280 L200,240 L260,210 L310,185 L380,155 L420,130 L470,110 L540,95" fill="none" stroke="#E75437" stroke-width="1.5" opacity="0.5"/>
                    <circle cx="140" cy="280" r="3" fill="#d4d4d4"/><circle cx="200" cy="240" r="3" fill="#d4d4d4"/><circle cx="260" cy="210" r="3" fill="#d4d4d4"/><circle cx="310" cy="185" r="3" fill="#d4d4d4"/><circle cx="380" cy="155" r="3" fill="#d4d4d4"/><circle cx="420" cy="130" r="3" fill="#d4d4d4"/><circle cx="470" cy="110" r="3" fill="#d4d4d4"/>
                    <circle cx="540" cy="95" r="5" fill="#E75437"/>
                    <text x="555" y="92" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" fill="#525252">Item A</text>
                    <text x="555" y="103" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Production capability</text>
                    <!-- Item B -->
                    <path d="M130,290 L180,270 L230,250 L280,230" fill="none" stroke="#E75437" stroke-width="1.5" opacity="0.3"/>
                    <path d="M280,230 C305,218 315,245 285,252 C265,256 252,242 270,232" fill="none" stroke="#E75437" stroke-width="1" opacity="0.2" stroke-dasharray="3 2"/>
                    <path d="M270,232 L330,210 L370,195" fill="none" stroke="#E75437" stroke-width="1.5" opacity="0.3"/>
                    <circle cx="130" cy="290" r="3" fill="#d4d4d4"/><circle cx="180" cy="270" r="3" fill="#d4d4d4"/><circle cx="230" cy="250" r="3" fill="#d4d4d4"/><circle cx="280" cy="230" r="2.5" fill="none" stroke="#d4d4d4" stroke-width="1"/><circle cx="330" cy="210" r="3" fill="#d4d4d4"/>
                    <circle cx="370" cy="195" r="5" fill="none" stroke="#E75437" stroke-width="1.5"/>
                    <text x="385" y="192" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" fill="#525252">Item B</text>
                    <text x="385" y="203" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Iterating — confidence insufficient at Gate 1</text>
                    <!-- Item C -->
                    <path d="M150,300 L190,282 L220,268" fill="none" stroke="#a3a3a3" stroke-width="1.5" opacity="0.4"/>
                    <circle cx="150" cy="300" r="3" fill="#d4d4d4"/><circle cx="190" cy="282" r="3" fill="#d4d4d4"/>
                    <circle cx="220" cy="268" r="5" fill="#a3a3a3"/>
                    <text x="235" y="265" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" fill="#a3a3a3">Item C</text>
                    <text x="235" y="276" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#c5c5c5">Signal collection underway</text>
                    <!-- Item D -->
                    <path d="M140,295 L190,275 L245,255 L295,240" fill="none" stroke="#a3a3a3" stroke-width="1.5" opacity="0.3"/>
                    <circle cx="140" cy="295" r="3" fill="#d4d4d4"/><circle cx="190" cy="275" r="3" fill="#d4d4d4"/><circle cx="245" cy="255" r="3" fill="#d4d4d4"/>
                    <line x1="291" y1="236" x2="299" y2="244" stroke="#ef4444" stroke-width="1.5" opacity="0.7"/><line x1="299" y1="236" x2="291" y2="244" stroke="#ef4444" stroke-width="1.5" opacity="0.7"/>
                    <text x="308" y="237" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" fill="#a3a3a3">Item D</text>
                    <text x="308" y="248" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#c5c5c5">Killed at gate</text>
                    <!-- Annotations -->
                    <circle cx="675" cy="62" r="4" fill="#E75437"/>
                    <text x="686" y="59" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" fill="#525252">Item A — Committed</text>
                    <text x="686" y="72" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Architecture hardened.</text>
                    <text x="686" y="84" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Operational SLAs defined.</text>
                    <text x="686" y="96" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Confidence threshold exceeded.</text>
                    <circle cx="675" cy="120" r="4" fill="none" stroke="#E75437" stroke-width="1.5"/>
                    <text x="686" y="117" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" fill="#525252">Item B — Validating</text>
                    <text x="686" y="130" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Confidence insufficient at Gate 1.</text>
                    <text x="686" y="142" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Hypothesis revised.</text>
                    <text x="686" y="154" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Validation continues.</text>
                    <circle cx="675" cy="178" r="4" fill="#a3a3a3"/>
                    <text x="686" y="175" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" fill="#525252">Item C — Exploring</text>
                    <text x="686" y="188" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Early signal collection.</text>
                    <text x="686" y="200" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">2 hypotheses discarded.</text>
                    <text x="686" y="212" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">No gate crossed.</text>
                    <g opacity="0.75">
                        <line x1="671" y1="232" x2="679" y2="240" stroke="#ef4444" stroke-width="1.5"/><line x1="679" y1="232" x2="671" y2="240" stroke="#ef4444" stroke-width="1.5"/>
                    </g>
                    <text x="686" y="233" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" font-weight="500" fill="#525252">Item D — Killed</text>
                    <text x="686" y="246" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Reached Gate 1, evidence insufficient.</text>
                    <text x="686" y="258" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Decision: kill, not iterate.</text>
                    <text x="686" y="270" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="9" fill="#a3a3a3">Investment recovered.</text>
                </svg>
            </div>
            <figcaption>
                Work advances incrementally. Individual capabilities promote only when confidence
                thresholds are exceeded. Multiple items may exist at different investment intensities
                simultaneously. Items that fail a gate may iterate or be killed outright.
                Promotion is explicit and governed by evidence — not time.
            </figcaption>
        </figure>
    </section>

    <PageNav
        prev={{ href: "/model/operating-model/", title: "Operating Model" }}
        next={{ href: "/practice/backlogs/", title: "Dual Backlogs" }}
    />
</BaseLayout>
