---
---

<canvas class="logo-sphere" id="logoSphere" aria-hidden="true"></canvas>

<script is:inline>
function initLogoSphere() {
  var el = document.getElementById('logoSphere');
  if (!el || el.dataset.init) return;
  el.dataset.init = '1';

  var SIZE = 44;
  var COUNT = 320;
  var COLOR = '#E75437';
  var PULL = 0.00004;
  var SPRING = 0.03;
  var FORM_DAMP = 0.08;
  var BLEND_SPEED = 0.06;
  var GAPS = 4;
  var GAP_WIDTH = 0.07;

  var dpr = window.devicePixelRatio || 1;
  el.width = SIZE * dpr;
  el.height = SIZE * dpr;
  el.style.width = SIZE + 'px';
  el.style.height = SIZE + 'px';

  var ctx = el.getContext('2d');
  if (!ctx) return;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

  var cx = SIZE / 2;
  var cy = SIZE / 2;
  var radius = SIZE / 2 - 1;

  var mouseX = 0, mouseY = 0, mouseActive = false;
  var blend = 0, forming = false;

  document.addEventListener('mousemove', function (e) {
    var rect = el.getBoundingClientRect();
    mouseX = Math.max(-3, Math.min(3, (e.clientX - rect.left - cx) / radius));
    mouseY = Math.max(-3, Math.min(3, (e.clientY - rect.top - cy) / radius));
    mouseActive = true;
  });
  document.addEventListener('mouseleave', function () { mouseActive = false; });
  el.addEventListener('mouseenter', function () { forming = true; });
  el.addEventListener('mouseleave', function () { forming = false; });

  var gapCenters = [];
  for (var g = 1; g <= GAPS; g++) gapCenters.push(-1 + (2 * g) / (GAPS + 1));

  var targets = [];
  for (var i = 0; i < COUNT; i++) {
    var tx, ty;
    while (true) {
      tx = (Math.random() - 0.5) * 2;
      ty = (Math.random() - 0.5) * 2;
      if (tx * tx + ty * ty > 0.88 * 0.88) continue;
      var inGap = false;
      for (var g = 0; g < gapCenters.length; g++) {
        if (Math.abs(tx - gapCenters[g]) < GAP_WIDTH) { inGap = true; break; }
      }
      if (inGap) continue;
      break;
    }
    targets.push({ x: tx, y: ty });
  }

  var particles = [];
  for (var i = 0; i < COUNT; i++) {
    var x, y;
    do { x = (Math.random() - 0.5) * 2; y = (Math.random() - 0.5) * 2; }
    while (x * x + y * y > 1);
    var speed = 0.002 + Math.random() * 0.005;
    var angle = Math.random() * Math.PI * 2;
    particles.push({
      x: x, y: y,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      r: 0.4 + Math.random() * 1.4,
      opacity: 0.25 + Math.random() * 0.7,
    });
  }

  function tick() {
    if (!document.body.contains(el)) return;

    blend += ((forming ? 1 : 0) - blend) * BLEND_SPEED;
    blend = Math.max(0, Math.min(1, blend));

    ctx.clearRect(0, 0, SIZE, SIZE);

    for (var j = 0; j < particles.length; j++) {
      var p = particles[j];
      var t = targets[j];

      if (blend > 0.01) {
        p.vx += (t.x - p.x) * SPRING * blend;
        p.vy += (t.y - p.y) * SPRING * blend;
        p.vx *= 1 - FORM_DAMP * blend;
        p.vy *= 1 - FORM_DAMP * blend;
      }

      var free = 1 - blend;
      if (free > 0.01) {
        if (mouseActive) {
          p.vx += (mouseX - p.x) * PULL * free;
          p.vy += (mouseY - p.y) * PULL * free;
        }
        p.x += (Math.random() - 0.5) * 0.002 * free;
        p.y += (Math.random() - 0.5) * 0.002 * free;
      }

      p.x += p.vx;
      p.y += p.vy;
      p.x *= 0.9997;
      p.y *= 0.9997;

      var dist = Math.sqrt(p.x * p.x + p.y * p.y);
      if (dist > 0.95) {
        var nx = p.x / dist, ny = p.y / dist;
        var dot = p.vx * nx + p.vy * ny;
        p.vx -= 2 * dot * nx;
        p.vy -= 2 * dot * ny;
        p.x *= 0.94 / dist;
        p.y *= 0.94 / dist;
      }

      var dr = p.r + (0.75 - p.r) * blend * 0.6;
      var da = p.opacity + (0.88 - p.opacity) * blend * 0.7;

      ctx.beginPath();
      ctx.arc(cx + p.x * radius, cy + p.y * radius, dr, 0, Math.PI * 2);
      ctx.fillStyle = COLOR;
      ctx.globalAlpha = da;
      ctx.fill();
    }
    ctx.globalAlpha = 1;
    requestAnimationFrame(tick);
  }

  requestAnimationFrame(tick);
}

initLogoSphere();
document.addEventListener('astro:page-load', initLogoSphere);
</script>
